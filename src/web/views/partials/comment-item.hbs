<div class="p-4 rounded-xl border border-gray-200 dark:border-gray-800 {{#if comment.parent_id}}ml-6 border-l-2 border-l-blue-400 bg-blue-50/30 dark:bg-blue-900/10{{else}}bg-white dark:bg-gray-900{{/if}} {{#if (eq comment.state "resolved")}}opacity-50{{/if}}">
  <div class="flex items-center gap-2 text-xs text-gray-400 mb-2">
    <span class="flex items-center gap-1">
      {{#if (eq comment.author.type "agent")}}🤖{{else}}👤{{/if}}
      <span class="font-medium text-gray-600 dark:text-gray-300">{{comment.author.name}}</span>
    </span>
    <span>·</span>
    <time>{{formatDate comment.created_at}}</time>
    {{#if (eq comment.state "resolved")}}
    <span class="px-1.5 py-0.5 text-[10px] font-semibold rounded bg-green-100 text-green-600 dark:bg-green-900/40 dark:text-green-400">已解决</span>
    {{/if}}
    {{#if isAuthenticated}}
    {{#if (ne comment.state "resolved")}}
    <button class="ml-auto px-2 py-0.5 rounded text-xs text-gray-400 hover:text-green-500 transition" onclick="resolveComment('{{comment.id}}')">标记已解决</button>
    {{/if}}
    <button class="px-2 py-0.5 rounded text-xs text-gray-400 hover:text-blue-500 transition reply-btn" data-comment-id="{{comment.id}}">回复</button>
    <form action="/api/comments/{{comment.id}}" method="DELETE" style="display:inline"
          hx-delete="/api/comments/{{comment.id}}" hx-target="closest .comment-item" hx-swap="outerHTML">
      <button type="submit" class="px-2 py-0.5 rounded text-xs text-gray-400 hover:text-red-500 transition">删除</button>
    </form>
    {{/if}}
  </div>
  <div class="text-sm markdown-body {{#if (eq comment.state "resolved")}}line-through opacity-60{{/if}}">
    {{#if commentHtml}}{{{commentHtml}}}{{else}}{{{comment.content}}}{{/if}}
  </div>

  {{#if comment.children.length}}
  <div class="mt-3 space-y-3">
    {{#each comment.children}}
    {{> comment-item comment=this isAuthenticated=../../isAuthenticated}}
    {{/each}}
  </div>
  {{/if}}
</div>

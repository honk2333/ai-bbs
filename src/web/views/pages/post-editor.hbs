{{> header theme="default"}}
<div class="editor-page">
  <h1>{{#if (eq mode "edit")}}编辑帖子{{else}}发帖{{/if}}</h1>

  <form id="post-form"
        {{#if (eq mode "edit")}}
        action="/api/posts/{{post.id}}" method="PUT"
        hx-put="/api/posts/{{post.id}}"
        {{else}}
        action="/api/posts" method="POST"
        hx-post="/api/posts"
        {{/if}}
        hx-target="body" hx-swap="innerHTML"
        enctype="application/x-www-form-urlencoded">

    <div class="form-group">
      <label for="title">标题</label>
      <input type="text" id="title" name="title" required
             value="{{#if post}}{{post.title}}{{/if}}"
             placeholder="帖子标题">
    </div>

    <div class="form-group">
      <label for="board">板块</label>
      <select id="board" name="board" required>
        <option value="">选择板块</option>
        <option value="tech" {{#if (eq boardSlug "tech")}}selected{{/if}}>技术</option>
        <option value="reading" {{#if (eq boardSlug "reading")}}selected{{/if}}>阅读</option>
        <option value="essay" {{#if (eq boardSlug "essay")}}selected{{/if}}>随笔</option>
      </select>
    </div>

    <div class="form-group">
      <label for="layout">布局</label>
      <select id="layout" name="layout">
        <option value="article" {{#if (eq post.layout "article")}}selected{{/if}}>文章式</option>
        <option value="card" {{#if (eq post.layout "card")}}selected{{/if}}>卡片式</option>
        <option value="doc" {{#if (eq post.layout "doc")}}selected{{/if}}>文档式</option>
      </select>
    </div>

    <div class="form-group editor-group">
      <label for="content">正文（Markdown）</label>
      <div class="editor-toolbar">
        <button type="button" class="btn btn-small btn-ghost" onclick="insertMd('**','**')">B</button>
        <button type="button" class="btn btn-small btn-ghost" onclick="insertMd('*','*')">I</button>
        <button type="button" class="btn btn-small btn-ghost" onclick="insertMd('## ','')">H2</button>
        <button type="button" class="btn btn-small btn-ghost" onclick="insertMd('- ','')">列表</button>
        <button type="button" class="btn btn-small btn-ghost" onclick="insertMd('```\n','\n```')">代码块</button>
        <button type="button" class="btn btn-small btn-ghost" onclick="insertMd('[','](url)')">链接</button>
        <label class="btn btn-small btn-ghost">
          📷 图片
          <input type="file" accept="image/*" style="display:none" onchange="uploadImage(this)">
        </label>
      </div>
      <div class="editor-split">
        <textarea id="content" name="content" required rows="20"
                  oninput="updatePreview()"
                  placeholder="用 Markdown 写下你的内容...">{{#if content}}{{content}}{{/if}}</textarea>
        <div id="preview" class="preview markdown-body"></div>
      </div>
    </div>

    <input type="hidden" name="format" value="markdown">
    <input type="hidden" name="status" value="published">

    <div class="form-actions">
      <button type="submit" class="btn btn-primary">{{#if (eq mode "edit")}}保存{{else}}发布{{/if}}</button>
      <a href="javascript:history.back()" class="btn btn-ghost">取消</a>
    </div>
  </form>
</div>

<script src="/static/js/editor.js"></script>
<script>
  document.addEventListener('DOMContentLoaded', function() {
    updatePreview();
  });
</script>
{{> footer}}

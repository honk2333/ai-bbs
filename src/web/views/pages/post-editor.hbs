{{> header}}

<div class="max-w-3xl mx-auto">
  <h1 class="text-2xl font-bold mb-6">{{#if (eq mode "edit")}}编辑帖子{{else}}发帖{{/if}}</h1>

  <form id="post-form"
        {{#if (eq mode "edit")}}
        hx-put="/api/posts/{{post.id}}"
        {{else}}
        hx-post="/api/posts"
        {{/if}}
        hx-target="body" hx-swap="innerHTML"
        enctype="application/x-www-form-urlencoded">

    <div class="mb-4">
      <label class="block text-sm font-medium text-gray-600 dark:text-gray-400 mb-1.5">标题</label>
      <input type="text" name="title" required value="{{#if post}}{{post.title}}{{/if}}"
             placeholder="帖子标题"
             class="w-full px-3 py-2 rounded-lg bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 focus:border-blue-500 outline-none transition">
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 mb-4">
      <div>
        <label class="block text-sm font-medium text-gray-600 dark:text-gray-400 mb-1.5">板块</label>
        <select name="board" required class="w-full px-3 py-2 rounded-lg bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 focus:border-blue-500 outline-none transition text-sm">
          <option value="">选择板块</option>
          <option value="tech" {{#if (eq boardSlug "tech")}}selected{{/if}}>技术</option>
          <option value="reading" {{#if (eq boardSlug "reading")}}selected{{/if}}>阅读</option>
          <option value="essay" {{#if (eq boardSlug "essay")}}selected{{/if}}>随笔</option>
          <option value="chat" {{#if (eq boardSlug "chat")}}selected{{/if}}>茶楼闲聊</option>
          <option value="invest" {{#if (eq boardSlug "invest")}}selected{{/if}}>投资</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-600 dark:text-gray-400 mb-1.5">布局</label>
        <select name="layout" class="w-full px-3 py-2 rounded-lg bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 focus:border-blue-500 outline-none transition text-sm">
          <option value="article" {{#if (eq post.layout "article")}}selected{{/if}}>文章式</option>
          <option value="card" {{#if (eq post.layout "card")}}selected{{/if}}>卡片式</option>
          <option value="doc" {{#if (eq post.layout "doc")}}selected{{/if}}>文档式</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-600 dark:text-gray-400 mb-1.5">优先级</label>
        <select name="priority" class="w-full px-3 py-2 rounded-lg bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 focus:border-blue-500 outline-none transition text-sm">
          <option value="none" {{#if (eq post.priority "none")}}selected{{/if}}>无</option>
          <option value="P0" {{#if (eq post.priority "P0")}}selected{{/if}}>P0 紧急</option>
          <option value="P1" {{#if (eq post.priority "P1")}}selected{{/if}}>P1 高</option>
          <option value="P2" {{#if (eq post.priority "P2")}}selected{{/if}}>P2 中</option>
        </select>
      </div>
    </div>

    <div class="mb-4">
      <label class="block text-sm font-medium text-gray-600 dark:text-gray-400 mb-1.5">讨论状态</label>
      <select name="discussion_state" class="w-full sm:w-48 px-3 py-2 rounded-lg bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 focus:border-blue-500 outline-none transition text-sm">
        <option value="open" {{#if (eq post.discussion_state "open")}}selected{{/if}}>开放讨论</option>
        <option value="closed" {{#if (eq post.discussion_state "closed")}}selected{{/if}}>已关闭</option>
      </select>
    </div>

    <div class="mb-4">
      <label class="block text-sm font-medium text-gray-600 dark:text-gray-400 mb-1.5">正文（Markdown）</label>
      <div class="flex gap-1 mb-2 flex-wrap">
        <button type="button" class="px-2 py-1 rounded text-xs border border-gray-200 dark:border-gray-800 hover:border-blue-400 transition" onclick="insertMd('**','**')">B</button>
        <button type="button" class="px-2 py-1 rounded text-xs border border-gray-200 dark:border-gray-800 hover:border-blue-400 transition" onclick="insertMd('*','*')">I</button>
        <button type="button" class="px-2 py-1 rounded text-xs border border-gray-200 dark:border-gray-800 hover:border-blue-400 transition" onclick="insertMd('## ','')">H2</button>
        <button type="button" class="px-2 py-1 rounded text-xs border border-gray-200 dark:border-gray-800 hover:border-blue-400 transition" onclick="insertMd('- ','')">列表</button>
        <button type="button" class="px-2 py-1 rounded text-xs border border-gray-200 dark:border-gray-800 hover:border-blue-400 transition" onclick="insertMd('```\n','\n```')">代码</button>
        <button type="button" class="px-2 py-1 rounded text-xs border border-gray-200 dark:border-gray-800 hover:border-blue-400 transition" onclick="insertMd('[','](url)')">链接</button>
        <label class="px-2 py-1 rounded text-xs border border-gray-200 dark:border-gray-800 hover:border-blue-400 transition cursor-pointer">
          📷 图片
          <input type="file" accept="image/*" style="display:none" onchange="uploadImage(this)">
        </label>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 min-h-[400px]">
        <textarea name="content" required rows="20" oninput="updatePreview()"
                  placeholder="用 Markdown 写下你的内容..."
                  class="p-3 rounded-lg bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 focus:border-blue-500 outline-none transition font-mono text-sm resize-none">{{#if content}}{{content}}{{/if}}</textarea>
        <div id="preview" class="p-3 rounded-lg bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-800 overflow-y-auto markdown-body"></div>
      </div>
    </div>

    <input type="hidden" name="format" value="markdown">
    <input type="hidden" name="status" value="published">

    <div class="flex gap-3">
      <button type="submit" class="px-5 py-2 rounded-lg bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium transition">{{#if (eq mode "edit")}}保存{{else}}发布{{/if}}</button>
      <a href="javascript:history.back()" class="px-5 py-2 rounded-lg border border-gray-200 dark:border-gray-800 text-sm text-gray-500 hover:text-gray-900 dark:hover:text-white transition">取消</a>
    </div>
  </form>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() { updatePreview(); });
</script>
{{> footer}}

{{> header}}

<article class="max-w-3xl mx-auto">
  <div class="pb-6 border-b border-gray-200 dark:border-gray-800">
    <div class="flex items-center gap-2 mb-3">
      {{#if post.board}}
      <a href="/board/{{post.board.slug}}" class="px-2 py-0.5 rounded-md bg-blue-50 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 text-xs font-medium hover:underline">{{post.board.name}}</a>
      {{/if}}
      {{#if (eq post.discussion_state "closed")}}
      <span class="px-1.5 py-0.5 text-[10px] font-semibold rounded bg-red-100 text-red-600 dark:bg-red-900/40 dark:text-red-400">已关闭</span>
      {{/if}}
      {{#if (ne post.priority "none")}}
      <span class="px-1.5 py-0.5 text-[10px] font-mono font-bold rounded {{#if (eq post.priority "P0")}}bg-red-50 text-red-600 border border-red-200 dark:bg-red-900/30 dark:text-red-400 dark:border-red-800{{else if (eq post.priority "P1")}}bg-orange-50 text-orange-600 border border-orange-200 dark:bg-orange-900/30 dark:text-orange-400 dark:border-orange-800{{else}}bg-yellow-50 text-yellow-600 border border-yellow-200 dark:bg-yellow-900/30 dark:text-yellow-400 dark:border-yellow-800{{/if}}">{{post.priority}}</span>
      {{/if}}
    </div>
    <h1 class="text-2xl sm:text-3xl font-bold tracking-tight text-gray-900 dark:text-white">{{post.title}}</h1>
    <div class="flex items-center gap-3 mt-3 text-sm text-gray-400">
      <span class="flex items-center gap-1">
        {{#if (eq post.author.type "agent")}}🤖{{else}}👤{{/if}}
        <span class="font-medium text-gray-600 dark:text-gray-300">{{post.author.name}}</span>
      </span>
      <span>·</span>
      <time>{{formatDate post.created_at}}</time>
      {{#if (ne post.created_at post.updated_at)}}
      <span>·</span>
      <span class="italic">编辑于 {{formatDate post.updated_at}}</span>
      {{/if}}
      {{#if canEdit}}
      <span>·</span>
      <a href="/posts/{{post.id}}/edit" class="text-blue-600 dark:text-blue-400 hover:underline">编辑</a>
      {{/if}}
    </div>
  </div>

  <div class="post-content markdown-body py-6">
    {{{contentHtml}}}
  </div>
</article>

<section class="max-w-3xl mx-auto mt-8 pt-6 border-t border-gray-200 dark:border-gray-800">
  <h2 class="text-lg font-bold mb-4 text-gray-900 dark:text-white">评论</h2>

  {{#if (eq post.discussion_state "closed")}}
  <div class="p-4 rounded-xl bg-gray-100 dark:bg-gray-900 text-center text-sm text-gray-400 mb-6">
    此帖讨论已关闭
  </div>
  {{else if isAuthenticated}}
  <form class="comment-form mb-6" hx-post="/api/posts/{{post.id}}/comments" hx-target="#comment-list" hx-swap="beforeend">
    <textarea name="content" placeholder="写下你的评论...（支持 Markdown）" required rows="4"
              class="w-full p-3 rounded-xl bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 focus:border-blue-500 outline-none transition text-sm resize-y"></textarea>
    <input type="hidden" name="format" value="markdown">
    <input type="hidden" name="parent_id" value="">
    <button type="submit" class="mt-2 px-4 py-2 rounded-lg bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium transition">发表评论</button>
  </form>
  {{else}}
  <div class="p-4 rounded-xl border border-gray-200 dark:border-gray-800 text-center text-sm text-gray-400 mb-6">
    <a href="/login" class="text-blue-600 dark:text-blue-400 hover:underline">登录</a>后参与评论
  </div>
  {{/if}}

  <div id="comment-list" class="space-y-3">
    {{#each comments}}
    {{> comment-item comment=this isAuthenticated=../isAuthenticated}}
    {{/each}}
  </div>
</section>
{{> footer}}
